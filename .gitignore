# ── Python ────────────────────────────────────────────────
venv/
__pycache__/
*.pyc
*.pyo
*.pyd
*.egg-info/
dist/
build/
.eggs/

# ── Test / coverage ───────────────────────────────────────
.pytest_cache/
.coverage
htmlcov/
*.cover

# ── Environment ───────────────────────────────────────────
.env
.env.*
!.env.example

# ── OS ────────────────────────────────────────────────────
.DS_Store
Thumbs.db

# ── Editor ────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo

# ── Tooling (local dev, not part of the project) ──────────
.claude/
.superpowers/
docs/superpowers/

# ── Index artifacts (auto-generated, never commit) ────────
indexes/*/chroma_db/
indexes/*/docstore.json
indexes/*/bm25_index.pkl/
indexes/*/bm25_index.pkl
indexes/*/leaf_nodes.pkl
indexes/*/.ingested_files.json

# ── User data (keep out of version control) ───────────────
indexes/*/data/

# ── Legacy root-level artifacts (pre-multi-index layout) ──
chroma_db/
docstore.json
bm25_index.pkl
leaf_nodes.pkl
.ingested_files.json

# ── Logs ──────────────────────────────────────────────────
*.log
logs/
